{
  "$id": "https://vectorforge.io/schemas/v0.2.0/pulsevector.payload.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "pulse": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "flow_slice_v1"
            },
            "flow_id": {
              "type": "string"
            },
            "tuple": {
              "additionalProperties": false,
              "properties": {
                "src_ip": {
                  "type": "string"
                },
                "src_port": {
                  "type": "integer"
                },
                "dst_ip": {
                  "type": "string"
                },
                "dst_port": {
                  "type": "integer"
                },
                "proto": {
                  "type": "string"
                },
                "ip_version": {
                  "type": "integer",
                  "enum": [4, 6]
                }
              },
              "required": [
                "src_ip",
                "src_port",
                "dst_ip",
                "dst_port",
                "proto"
              ],
              "type": "object"
            },
            "timing": {
              "additionalProperties": false,
              "properties": {
                "first_seen_us": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Microsecond epoch timestamp of the first packet"
                },
                "last_seen_us": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Microsecond epoch timestamp of the last packet"
                },
                "duration_us": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Flow duration in microseconds"
                }
              },
              "required": [
                "first_seen_us",
                "last_seen_us",
                "duration_us"
              ],
              "type": "object"
            },
            "stats": {
              "additionalProperties": false,
              "properties": {
                "bytes_out": {
                  "minimum": 0,
                  "type": "integer"
                },
                "bytes_in": {
                  "minimum": 0,
                  "type": "integer"
                },
                "packets_out": {
                  "minimum": 0,
                  "type": "integer"
                },
                "packets_in": {
                  "minimum": 0,
                  "type": "integer"
                },
                "retransmits": {
                  "minimum": 0,
                  "type": "integer"
                },
                "rst_count": {
                  "minimum": 0,
                  "type": "integer"
                },
                "fin_count": {
                  "minimum": 0,
                  "type": "integer"
                },
                "syn_count": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "bytes_out",
                "bytes_in",
                "packets_out",
                "packets_in"
              ],
              "type": "object"
            },
            "tls": {
              "additionalProperties": false,
              "properties": {
                "version": {
                  "type": "string",
                  "description": "TLS version (e.g. 'TLS 1.3', 'TLS 1.2')"
                },
                "cipher_suite": {
                  "type": "string"
                },
                "sni": {
                  "type": "string",
                  "description": "Server Name Indication value"
                },
                "issuer": {
                  "type": "string"
                },
                "subject": {
                  "type": "string"
                },
                "cert_fingerprint_sha256": {
                  "type": "string",
                  "description": "SHA-256 fingerprint of the server certificate"
                },
                "extensions": {
                  "type": "object"
                }
              },
              "type": "object"
            },
            "dns": {
              "additionalProperties": false,
              "properties": {
                "query_name": {
                  "type": "string"
                },
                "query_type": {
                  "type": "string",
                  "description": "DNS record type (e.g. 'A', 'AAAA', 'CNAME', 'MX')"
                },
                "response_code": {
                  "type": "string",
                  "description": "DNS response code (e.g. 'NOERROR', 'NXDOMAIN')"
                },
                "answers": {
                  "items": {
                    "additionalProperties": false,
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "value": {
                        "type": "string"
                      },
                      "ttl": {
                        "type": "integer",
                        "minimum": 0
                      }
                    },
                    "required": ["type", "value"],
                    "type": "object"
                  },
                  "type": "array"
                },
                "extensions": {
                  "type": "object"
                }
              },
              "type": "object"
            },
            "http": {
              "additionalProperties": false,
              "properties": {
                "method": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "status_code": {
                  "type": "integer"
                },
                "host": {
                  "type": "string"
                },
                "user_agent": {
                  "type": "string"
                },
                "content_type": {
                  "type": "string"
                },
                "extensions": {
                  "type": "object"
                }
              },
              "type": "object"
            },
            "fingerprints": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "kind": {
                    "type": "string",
                    "description": "Fingerprint type (e.g. 'ja3', 'ja3s', 'ja4', 'hassh', 'flow_behavior', 'dns_pattern', 'cert_fingerprint')"
                  },
                  "value": {
                    "type": "string",
                    "description": "Fingerprint hash or value"
                  },
                  "raw": {
                    "type": "string",
                    "description": "Raw fingerprint string before hashing (optional)"
                  }
                },
                "required": ["kind", "value"],
                "type": "object"
              },
              "type": "array"
            },
            "classification": {
              "additionalProperties": false,
              "properties": {
                "traffic_type": {
                  "type": "string",
                  "description": "Classified traffic type (e.g. 'web_browsing', 'dns', 'streaming', 'unknown')"
                },
                "confidence_pct": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Classification confidence as integer percentage"
                },
                "model": {
                  "type": "string"
                }
              },
              "required": ["traffic_type", "confidence_pct", "model"],
              "type": "object"
            },
            "entity_id": {
              "type": ["string", "null"],
              "description": "Correlated entity identifier"
            },
            "correlation": {
              "additionalProperties": false,
              "properties": {
                "method": {
                  "type": "string"
                },
                "entity_ids": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "confidence_pct": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                }
              },
              "required": ["method"],
              "type": ["object", "null"]
            },
            "session_id": {
              "type": "string"
            },
            "extensions": {
              "type": "object"
            }
          },
          "required": [
            "kind",
            "flow_id",
            "tuple",
            "timing",
            "stats"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "net_event_v1"
            },
            "event_type": {
              "type": "string"
            },
            "occurred_us": {
              "minimum": 0,
              "type": "integer"
            },
            "severity": {
              "type": "string",
              "enum": ["info", "warning", "error", "critical"]
            },
            "attributes": {
              "type": "object"
            },
            "fingerprints": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  },
                  "raw": {
                    "type": "string"
                  }
                },
                "required": ["kind", "value"],
                "type": "object"
              },
              "type": "array"
            },
            "session_id": {
              "type": "string"
            },
            "extensions": {
              "type": "object"
            }
          },
          "required": [
            "kind",
            "event_type",
            "occurred_us"
          ],
          "type": "object"
        }
      ]
    }
  },
  "required": [
    "pulse"
  ],
  "title": "PulseVector Payload Schema (v0.2.0)",
  "type": "object"
}
