{
  "$id": "https://vectorforge.io/schemas/v0.2.0/rfvector.payload.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "rf": {
      "additionalProperties": false,
      "properties": {
        "band": {
          "additionalProperties": false,
          "properties": {
            "center_hz": {
              "minimum": 0,
              "type": "integer"
            },
            "span_hz": {
              "minimum": 1,
              "type": "integer"
            }
          },
          "required": [
            "center_hz",
            "span_hz"
          ],
          "type": "object"
        },
        "sample_rate_hz": {
          "minimum": 1,
          "type": "integer"
        },
        "duration_ms": {
          "minimum": 1,
          "type": "integer"
        },
        "spectral_measurements": {
          "additionalProperties": false,
          "properties": {
            "peak_power_dBm_x100": {
              "type": "integer",
              "description": "Peak power in dBm * 100 (fixed-point, e.g. -3050 = -30.50 dBm)"
            },
            "mean_power_dBm_x100": {
              "type": "integer",
              "description": "Mean power in dBm * 100 (fixed-point)"
            },
            "noise_floor_dBm_x100": {
              "type": "integer",
              "description": "Noise floor in dBm * 100 (fixed-point)"
            },
            "snr_dB_x100": {
              "type": "integer",
              "minimum": 0,
              "description": "Signal-to-noise ratio in dB * 100 (fixed-point)"
            },
            "flatness_x10000": {
              "type": "integer",
              "minimum": 0,
              "maximum": 10000,
              "description": "Spectral flatness ratio * 10000 (0 = tonal, 10000 = white noise)"
            },
            "variance_x10000": {
              "type": "integer",
              "minimum": 0,
              "description": "Spectral variance * 10000 (fixed-point)"
            },
            "peak_to_average_dB_x100": {
              "type": "integer",
              "minimum": 0,
              "description": "Peak-to-average power ratio in dB * 100"
            }
          },
          "required": [
            "peak_power_dBm_x100",
            "mean_power_dBm_x100",
            "noise_floor_dBm_x100",
            "snr_dB_x100"
          ],
          "type": "object"
        },
        "location": {
          "additionalProperties": false,
          "properties": {
            "lat_udeg": {
              "type": "integer",
              "description": "Latitude in microdegrees (e.g. 37774929 = 37.774929°)"
            },
            "lon_udeg": {
              "type": "integer",
              "description": "Longitude in microdegrees"
            },
            "alt_mm": {
              "type": "integer",
              "description": "Altitude above WGS84 ellipsoid in millimetres"
            },
            "accuracy_mm": {
              "type": "integer",
              "minimum": 0,
              "description": "Horizontal accuracy radius in millimetres"
            },
            "bearing_mdeg": {
              "type": "integer",
              "minimum": 0,
              "maximum": 360000,
              "description": "Antenna bearing in millidegrees (0-360000)"
            },
            "aoa_mdeg": {
              "type": "integer",
              "description": "Angle of arrival in millidegrees"
            }
          },
          "required": [
            "lat_udeg",
            "lon_udeg"
          ],
          "type": "object"
        },
        "classification": {
          "additionalProperties": false,
          "properties": {
            "signal_type": {
              "type": "string",
              "description": "Classified signal type (e.g. 'wifi', 'lte', 'fm_broadcast', 'unknown')"
            },
            "confidence_pct": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Classification confidence as integer percentage (0-100)"
            },
            "model": {
              "type": "string",
              "description": "Classification model identifier"
            }
          },
          "required": [
            "signal_type",
            "confidence_pct",
            "model"
          ],
          "type": "object"
        },
        "entity_id": {
          "type": "string",
          "description": "Correlated entity identifier linking captures from the same emitter"
        },
        "correlation": {
          "additionalProperties": false,
          "properties": {
            "method": {
              "type": "string",
              "description": "Correlation method used (e.g. 'fingerprint_match', 'manual')"
            },
            "entity_ids": {
              "items": {
                "type": "string"
              },
              "type": "array",
              "description": "Related entity identifiers"
            },
            "confidence_pct": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          },
          "required": [
            "method"
          ],
          "type": "object"
        },
        "hardware": {
          "additionalProperties": false,
          "properties": {
            "antenna_model": {
              "type": "string"
            },
            "gain_dB_x100": {
              "type": "integer",
              "description": "Antenna gain in dB * 100 (fixed-point)"
            },
            "receiver": {
              "type": "string",
              "description": "Receiver model identifier"
            }
          },
          "type": "object"
        },
        "fingerprints": {
          "items": {
            "oneOf": [
              {
                "additionalProperties": false,
                "properties": {
                  "kind": {
                    "const": "wavelet_fingerprint_v1"
                  },
                  "matrix": {
                    "items": {
                      "items": {
                        "type": "integer"
                      },
                      "maxItems": 3,
                      "minItems": 3,
                      "type": "array"
                    },
                    "maxItems": 3,
                    "minItems": 3,
                    "type": "array"
                  },
                  "params": {
                    "additionalProperties": false,
                    "properties": {
                      "decomp_level": {
                        "minimum": 1,
                        "type": "integer"
                      },
                      "normalized": {
                        "type": "boolean"
                      },
                      "wavelet": {
                        "type": "string"
                      },
                      "window_ms": {
                        "minimum": 1,
                        "type": "integer"
                      }
                    },
                    "required": [
                      "window_ms",
                      "wavelet",
                      "decomp_level",
                      "normalized"
                    ],
                    "type": "object"
                  },
                  "scale": {
                    "minimum": 1,
                    "type": "integer"
                  }
                },
                "required": [
                  "kind",
                  "scale",
                  "matrix",
                  "params"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "codec": {
                    "type": "string"
                  },
                  "data_b64": {
                    "type": "string"
                  },
                  "df_hz": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "dt_us": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "f0_hz": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "kind": {
                    "const": "spectral_tile_v1"
                  },
                  "quant": {
                    "type": "object"
                  },
                  "shape": {
                    "additionalProperties": false,
                    "properties": {
                      "f": {
                        "minimum": 1,
                        "type": "integer"
                      },
                      "t": {
                        "minimum": 1,
                        "type": "integer"
                      }
                    },
                    "required": [
                      "t",
                      "f"
                    ],
                    "type": "object"
                  },
                  "t0_us": {
                    "minimum": 0,
                    "type": "integer"
                  }
                },
                "required": [
                  "kind",
                  "t0_us",
                  "dt_us",
                  "f0_hz",
                  "df_hz",
                  "shape",
                  "codec",
                  "data_b64"
                ],
                "type": "object"
              },
              {
                "additionalProperties": false,
                "properties": {
                  "dim": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "kind": {
                    "const": "embedding_v1"
                  },
                  "model": {
                    "type": "string"
                  },
                  "vector_b64": {
                    "type": "string"
                  }
                },
                "required": [
                  "kind",
                  "model",
                  "dim",
                  "vector_b64"
                ],
                "type": "object"
              }
            ]
          },
          "minItems": 1,
          "type": "array"
        },
        "detections": {
          "items": {
            "type": "object"
          },
          "type": "array"
        },
        "emitter_hint": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "extensions": {
          "type": "object"
        }
      },
      "required": [
        "band",
        "sample_rate_hz",
        "duration_ms",
        "fingerprints"
      ],
      "type": "object"
    }
  },
  "required": [
    "rf"
  ],
  "title": "RFVector Payload Schema (v0.2.0)",
  "type": "object"
}
