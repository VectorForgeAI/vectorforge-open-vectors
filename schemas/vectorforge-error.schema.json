  "properties": {
    "capture_index": {
      "type": "integer"
    },
    "capture_key": {
      "type": "string"
    },
    "details": {
      "type": "object"
    },
    "error_message": {
      "type": "string"
    },
    "error_type": {
      "type": "string"
    },
    "retryable": {
      "type": "boolean"
    },
    "source_file": {
      "type": "string"
    },
    "source_uri": {
      "type": "string"
    }
