          "cc": {
            "type": [
              "number",
              "null"
            ]
          },
          "ef": {
            "type": [
              "number",
              "null"
            ]
          },
          "end_us": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          },
          "pf": {
            "type": "number"
          },
          "start_us": {
            "type": "integer"
          },
          "stream_id": {
            "type": "string"
          }
